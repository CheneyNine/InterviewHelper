# Shared server-side configuration for Core API and Interviewer.
# Copy to .env and fill secrets locally. Never commit the real .env.

DATABASE_PATH=./services/api/data/interview_helper.db
INTERVIEWER_BASE_URL=http://127.0.0.1:8001

# When Core API runs on the same computer as an SSH tunnel:
VLM_BASE_URL=http://127.0.0.1:50021/v1
# When Core API runs on the remote model server instead:
# VLM_BASE_URL=http://127.0.0.1:8002/v1
VLM_API_STYLE=openai
VLM_API_KEY=<qwen-server-secret>
VLM_MODEL=Qwen3-Omni-30B-A3B-Instruct
VLM_USE_AUDIO_IN_VIDEO=true
VLM_TIMEOUT_SECONDS=900
MAX_MEDIA_BYTES=209715200

# Question generation, answer scoring and final report all use ECNU.
MODEL_PROVIDER=ecnu
ECNU_BASE_URL=https://chat.ecnu.edu.cn/open/api/v1
ECNU_MODEL=ecnu-reasoner
ECNU_API_KEYS="
main=<ecnu-key-1>
backup=<ecnu-key-2>
"
MODEL_TIMEOUT_SECONDS=180
# Ignore system HTTP_PROXY/HTTPS_PROXY by default to avoid proxy-induced TLS
# resets when connecting directly to ECNU.
MODEL_TRUST_ENV=false
