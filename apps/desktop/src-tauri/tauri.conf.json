{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InterviewHelper",
  "version": "0.1.0",
  "identifier": "com.interviewhelper.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "label": "main",
      "title": "InterviewHelper",
      "width": 1280,
      "height": 820,
      "minWidth": 900,
      "minHeight": 680,
      "resizable": true,
      "fullscreen": false,
      "center": true
    }],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* https:; img-src 'self' blob: data:; media-src 'self' blob: mediastream:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Education",
    "shortDescription": "AI 模拟面试训练工具",
    "longDescription": "根据岗位描述生成问题，逐题录制回答并获得结构化训练建议。",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
